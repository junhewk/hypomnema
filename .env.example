# Hypomnema — Environment Variables
# Copy to .env and fill in as needed.

# ── Deployment mode ────────────────────────────────────────
# "local" (default) — localhost dev, "server" — remote/Docker, "desktop" — native window (pywebview)
# HYPOMNEMA_MODE=local

# ── Network ────────────────────────────────────────────────
# HYPOMNEMA_HOST=127.0.0.1        # Bind address (server mode defaults to 0.0.0.0)
# HYPOMNEMA_PORT=8073             # App port (NiceGUI serves both UI and API)

# ── Database ───────────────────────────────────────────────
# HYPOMNEMA_DB_PATH=data/hypomnema.db

# ── LLM Provider ──────────────────────────────────────────
# Options: claude, google, openai, ollama, mock
# HYPOMNEMA_LLM_PROVIDER=mock
# HYPOMNEMA_LLM_MODEL=              # Provider-specific model ID

# ── API Keys ──────────────────────────────────────────────
# HYPOMNEMA_ANTHROPIC_API_KEY=
# HYPOMNEMA_GOOGLE_API_KEY=
# HYPOMNEMA_OPENAI_API_KEY=

# ── Ollama / OpenAI-compatible ────────────────────────────
# HYPOMNEMA_OLLAMA_BASE_URL=http://localhost:11434
# HYPOMNEMA_OPENAI_BASE_URL=       # Custom OpenAI-compatible endpoint

# ── Embedding Provider ────────────────────────────────────
# Options: local (sentence-transformers), openai, google
# Changing this at runtime triggers a full knowledge graph rebuild.
# HYPOMNEMA_EMBEDDING_PROVIDER=local
# HYPOMNEMA_EMBEDDING_MODEL=all-MiniLM-L6-v2
# HYPOMNEMA_EMBEDDING_DIM=384

# ── Auth (server mode only) ──────────────────────────────
# Pre-set passphrase for Docker/server mode (skips first-run setup).
# HYPOMNEMA_PASSPHRASE=

# ── Feeds ─────────────────────────────────────────────────
# HYPOMNEMA_TRIAGE_THRESHOLD=0.3   # 0.0–1.0, relevance gate for automated feeds
# HYPOMNEMA_FEED_FETCH_TIMEOUT=30  # Seconds

# ── Advanced ──────────────────────────────────────────────
# HYPOMNEMA_SQLITE_VEC_PATH=       # Override sqlite-vec extension path (auto-detect if empty)
# HYPOMNEMA_STATIC_DIR=            # Static assets dir (icon, logo)
# HYPOMNEMA_JSON_LOGS=0            # Set to 1 for JSON-structured log output
