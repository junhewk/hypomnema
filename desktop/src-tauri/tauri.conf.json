{
  "$schema": "https://raw.githubusercontent.com/nickel-org/tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "Hypomnema",
  "version": "0.1.0",
  "identifier": "com.hypomnema.app",
  "build": {
    "frontendDist": "../../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "Hypomnema",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/hypomnema-server/"
    ],
    "licenseFile": "../../LICENSE"
  }
}
